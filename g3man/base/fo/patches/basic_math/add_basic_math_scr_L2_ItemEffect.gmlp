meta:
targets = 'gml_GlobalScript_scr_L2_ItemEffect'
critical = true

patch:
find_line_with('_Amt = round(PegNum * 0.3)')

write('
if (scr_FO_is_challenge("basicmath"))
{
    _Amt = round(PegNum * 0.5);
}
')


find_line_with('_Amt = PegNum * 0.3')

write('
if (scr_FO_is_challenge("basicmath"))
{
    _Amt = PegNum * 0.5;
}
')