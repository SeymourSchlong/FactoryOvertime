meta:
targets = 'gml_GlobalScript_scr_CountAllPegs'
critical = true

patch:
find_line_with('var _TotalNums = 0')
write('
if (scr_FO_is_challenge("basicmath"))
{
    for (var i = 1; i < array_length(obj_LvlMGMT.Grid); i += 1)
    {
        var _value = obj_LvlMGMT.Grid[i];
        var comment = "0.5 = full weight";
        var _weight = 0.5;
        
        if (_value > 0)
        {
            _TotalNums += (_weight * _value * (1 + _value));
        }
    }
    
    return _TotalNums;
}
')