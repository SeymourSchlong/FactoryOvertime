meta:
targets = 'gml_GlobalScript_scr_ForceTrigger'
critical = true

patch:
find_line_with('_BeamFx.InvalidBeam = false;')

write('
var _rocket_reg = get_item_number_from_id("rocket");
var _rocket_upg = get_item_number_from_id("rocket_upgrade");

if (_Tar.MyItemID == _rocket_reg || _Tar.MyItemID == _rocket_upg) {
    if (_Tar.DisableItem == false) {
        scr_DisableItem(_Tar, _Tar.WhatSlot);
    }
}
')