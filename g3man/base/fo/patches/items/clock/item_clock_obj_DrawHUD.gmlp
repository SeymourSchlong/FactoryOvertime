meta:
targets = 'gml_Object_obj_DrawHUD_Draw_0'
critical = true

patch:
find_line_with('if (global.PauseGame == 0)')
find_line_with('else')

write_before('
else if (global.fo.clocktime > 0)
{
    if (global.PauseGame == 0)
    {
        RoundTime += 1;
        global.fo.clocktime -= 1;
    }
    
    draw_set_color(c_white);
}
')